### Button (Primary)
  Button (Primary) component
  Props:
    - onClick: (event: React.SyntheticEvent) => void (optional) — Fired when the user clicks / activates the primitive.
    - onHover: (event: React.SyntheticEvent) => void (optional) — Fired when the mouse enters.
    - isDisabled: boolean (optional) — Disable the primitive.
    - isLoading: boolean (optional) — Show a loading spinner. Also implies disabled.
    - children: React.ReactNode (optional) — Content rendered inside the primitive.
    - icon: React.ReactNode (optional) — Optional leading icon (React node).
    - sx: Record<string, unknown> (optional) — Extra sx overrides merged on top of the manifest-driven styles.
    - className: string (optional) — Extra className to append.
    - type: 'textButton' | 'iconButton' (optional) — Figma variant axis: "Type" (values: "Text button" → textButton, "Icon button" → iconButton)
    - size: 'lg' | 'md' | 'sm' | 'xs' (optional) — Figma variant axis: "Size" (values: "lg" → lg, "md" → md, "sm" → sm, "xs" → xs)
    - width: 'compact' | 'fluidBlock' (optional) — Figma variant axis: "Width" (values: "Compact" → compact, "Fluid/block" → fluidBlock)
    - state: 'default' | 'hover' | 'focus' | 'disabled' (optional) — Figma variant axis: "State" (values: "Default" → default, "Hover" → hover, "Focus" → focus, "Disabled" → disabled)

